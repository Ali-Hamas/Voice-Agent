# ===== Copy this file to .env and fill in your real values =====
# Never commit .env to git.

# --- OpenAI Realtime ---
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# --- Server ---
# Public hostname that Twilio + Google can reach. No https://, no trailing slash.
# Local dev: <your-tunnel>.trycloudflare.com   |   Production: va.yourdomain.com
PUBLIC_HOST=va.yourdomain.com
PORT=8000
LOG_LEVEL=INFO

# Random secret used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Google Calendar OAuth (per-tenant calendar booking) ---
# Get these from https://console.cloud.google.com/  (OAuth client ID, Web app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/admin/google/callback
